SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=mumaid
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0

# Dev email (Mailpit): SMTP 1025, inbox http://localhost:8025. In Docker, compose sets EMAIL_HOST=mailpit.
# Use EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend to skip SMTP and print in logs.
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=MumAid <noreply@mumaid.local>
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

OTP_EXPIRY_SECONDS=300

CORS_ALLOWED_ORIGINS=
