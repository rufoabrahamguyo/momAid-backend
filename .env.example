SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Django reads POSTGRES_NAME; Docker Compose Postgres image uses POSTGRES_DB (keep both in sync locally).
POSTGRES_NAME=mumaid
POSTGRES_DB=mumaid
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Production (Neon/Render): TLS required; set POSTGRES_SSL_REQUIRE=False only for local Postgres without SSL.
# POSTGRES_SSL_REQUIRE=true

REDIS_URL=redis://localhost:6379/0

# true = enqueue OTP email to Celery (use with a worker). false = send in the web process (e.g. Render without a worker). Defaults: dev settings true, prod false; override with this in any environment.
# EMAIL_USE_CELERY=true

EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

CLIENT_GOOGLE_ID=your_google_client_id


TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

OTP_EXPIRY_SECONDS=300

CORS_ALLOWED_ORIGINS=
